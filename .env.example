INQUIRY_TO_EMAIL=info@xlwinch.com

# Alibaba Cloud Enterprise Mail / Aliyun Qiye Mail SMTP
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@xlwinch.com
SMTP_PASS=your_email_authorization_code_or_password
SMTP_FROM_EMAIL=info@xlwinch.com

# Optional: keep this empty unless you also send leads to CRM / automation.
INQUIRY_WEBHOOK_URL=
INQUIRY_WEBHOOK_TOKEN=

# Optional SEO / ads tracking.
# Google Search Console gives this value in the HTML tag:
# <meta name="google-site-verification" content="PASTE_THIS_PART_HERE" />
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional Google Tag Manager container ID, for example GTM-XXXXXXX.
NEXT_PUBLIC_GTM_ID=
